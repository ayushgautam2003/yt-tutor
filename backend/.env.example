OPENAI_API_KEY=your_openai_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here

# ── LLM fine-tuning ────────────────────────────────────────
MODEL_NAME=gpt-4o
TEMPERATURE=0.3
MAX_TOKENS=512
TOP_P=1.0
FREQUENCY_PENALTY=0.0
PRESENCE_PENALTY=0.0

# ── RAG / retrieval ────────────────────────────────────────
RETRIEVAL_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Teaching behaviour ─────────────────────────────────────
TEACHING_LEVEL=beginner
RESPONSE_STYLE=concise

# ── LangSmith monitoring (optional) ───────────────────────
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=yt-tutor
LANGCHAIN_TRACING_V2=false

# ── Proxy (required for hosted deployment to bypass YouTube IP block) ──
# Sign up free at webshare.io → Proxy → username:password@proxy.webshare.io:80
WEBSHARE_PROXY_URL=username:password@proxy.webshare.io:80
